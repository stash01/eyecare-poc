# ─── Database (Supabase — Canada Central region) ─────────────────────────────
# Create a project at https://supabase.com — select Canada (Central) region.
# Run migrations/001_initial_schema.sql against your project.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # Settings > API > service_role (NEVER NEXT_PUBLIC_)

# ─── Health card encryption ───────────────────────────────────────────────────
# Generate: openssl rand -hex 32
HEALTH_CARD_ENCRYPTION_KEY=your-64-char-hex-key

# ─── Jane App (Phase 2 — leave blank until Jane API credentials are obtained) ─
# Request API access at https://jane.app/developers
JANE_CLIENT_ID=
JANE_CLIENT_SECRET=
JANE_BASE_URL=https://your-clinic.janeapp.com

# ─── Stripe (Phase 4 — replace subscription mock with real billing) ────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── App ──────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000  # set to your production URL in prod
NODE_ENV=development
